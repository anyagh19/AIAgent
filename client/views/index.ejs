<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>AI Assistant – Voice Chat</title>
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Plus Jakarta Sans Font -->
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
  <!-- Marked.js for Markdown rendering -->
  <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
  
  <style>
    body { 
      font-family: 'Plus Jakarta Sans', sans-serif; 
      background-color: #f8fafc; 
      overflow: hidden;
    }

    /* Animated background gradient mesh */
    .mesh-gradient {
      position: absolute;
      width: 100%;
      height: 100%;
      z-index: -2;
      background-color: #f8fafc;
      background-image: 
        radial-gradient(at 0% 0%, rgba(99, 102, 241, 0.08) 0px, transparent 50%),
        radial-gradient(at 100% 0%, rgba(168, 85, 247, 0.08) 0px, transparent 50%),
        radial-gradient(at 50% 100%, rgba(16, 185, 129, 0.05) 0px, transparent 50%);
      opacity: 0.9;
    }

    .waveform {
      display: flex;
      align-items: center;
      gap: 3px;
      height: 32px;
    }
    .wave-bar {
      width: 3px;
      height: 6px;
      background-color: #6366f1;
      border-radius: 4px;
      transition: height 0.15s ease, background-color 0.3s ease;
    }
    .waveform.active .wave-bar {
      animation: soundwave 1.2s ease-in-out infinite alternate;
    }
    .waveform.active .wave-bar:nth-child(2) { animation-delay: 0.1s; }
    .waveform.active .wave-bar:nth-child(3) { animation-delay: 0.2s; }
    .waveform.active .wave-bar:nth-child(4) { animation-delay: 0.3s; }
    .waveform.active .wave-bar:nth-child(5) { animation-delay: 0.4s; }
    .waveform.active .wave-bar:nth-child(6) { animation-delay: 0.5s; }
    .waveform.active .wave-bar:nth-child(7) { animation-delay: 0.6s; }

    @keyframes soundwave {
      0% { height: 6px; }
      100% { height: 28px; }
    }

    /* Message animation reveal */
    .msg-card {
      opacity: 0;
      transform: translateY(16px);
      animation: msgReveal 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
    @keyframes msgReveal {
      to { opacity: 1; transform: translateY(0); }
    }

    /* Blink cursor typewriter style */
    .typing::after {
      content: '';
      display: inline-block;
      width: 6px;
      height: 14px;
      background-color: #6366f1;
      margin-left: 4px;
      animation: blink 0.8s infinite;
      vertical-align: middle;
    }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

    /* Shimmer loading helper */
    .loading-shimmer {
      background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 50%, #f1f5f9 75%);
      background-size: 200% 100%;
      animation: shimmer 1.5s infinite;
      color: transparent !important;
      border-radius: 6px;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

    /* Custom high-performance scrolling */
    #chat-container::-webkit-scrollbar { width: 6px; }
    #chat-container::-webkit-scrollbar-track { background: transparent; }
    #chat-container::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 99px; }
    #chat-container::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

    .glass-panel {
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.6);
    }

    .glass-input {
      background: rgba(255, 255, 255, 0.85);
      backdrop-filter: blur(16px);
      border: 1px solid rgba(0, 0, 0, 0.04);
      box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.03);
    }

    /* Listening states classes */
    .mic-listening {
      background-color: #ef4444 !important;
      animation: pulseAlert 1.6s infinite;
    }
    @keyframes pulseAlert {
      0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
      70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
      100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }

    /* Speaking indicator */
    .speaking-indicator {
      animation: pulseSpeaking 1.2s infinite;
      background-color: #8b5cf6 !important;
    }
    @keyframes pulseSpeaking {
      0% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.4); }
      70% { box-shadow: 0 0 0 10px rgba(139, 92, 246, 0); }
      100% { box-shadow: 0 0 0 0 rgba(139, 92, 246, 0); }
    }

    /* Sidebar transitions */
    .sidebar-drawer {
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Markdown styles inside AI messages */
    .markdown-content {
      line-height: 1.7;
    }
    .markdown-content h1, .markdown-content h2, .markdown-content h3 {
      font-weight: 700;
      margin-top: 1em;
      margin-bottom: 0.5em;
    }
    .markdown-content h1 { font-size: 1.5em; }
    .markdown-content h2 { font-size: 1.25em; }
    .markdown-content h3 { font-size: 1.1em; }
    .markdown-content ul, .markdown-content ol {
      padding-left: 1.5em;
      margin: 0.5em 0;
    }
    .markdown-content li {
      list-style-type: disc;
      margin-bottom: 0.2em;
    }
    .markdown-content code {
      background: #f1f5f9;
      padding: 0.2em 0.4em;
      border-radius: 4px;
      font-size: 0.9em;
      font-family: 'Courier New', monospace;
    }
    .markdown-content pre {
      background: #1e293b;
      color: #e2e8f0;
      padding: 1em;
      border-radius: 8px;
      overflow-x: auto;
      margin: 0.5em 0;
    }
    .markdown-content pre code {
      background: transparent;
      padding: 0;
      color: inherit;
    }
    .markdown-content blockquote {
      border-left: 4px solid #6366f1;
      padding-left: 1em;
      margin: 0.5em 0;
      color: #475569;
      font-style: italic;
    }
    .markdown-content a {
      color: #6366f1;
      text-decoration: underline;
    }
    .markdown-content p {
      margin: 0.5em 0;
    }
  </style>
</head>

<body class="flex h-screen text-slate-800 relative select-none">
  <!-- Interactive Mesh background -->
  <div class="mesh-gradient"></div>

  <!-- Settings Drawer -->
  <div id="settingsDrawer" class="sidebar-drawer fixed right-0 top-0 bottom-0 w-80 bg-white shadow-2xl border-l border-slate-100 z-50 translate-x-full flex flex-col">
    <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <h3 class="font-bold text-slate-800">Voice settings</h3>
      </div>
      <button onclick="toggleDrawer()" class="p-2 hover:bg-slate-100 rounded-full text-slate-400 hover:text-slate-600 transition-colors">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto p-6 space-y-6">
      <!-- Voice Selector -->
      <div>
        <label class="block text-xs font-bold uppercase tracking-wider text-slate-500 mb-2">Synthesis Voice</label>
        <select id="voiceSelect" class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500/20 text-slate-700"></select>
      </div>
      <!-- Speech Speed -->
      <div>
        <div class="flex justify-between items-center mb-1">
          <label class="text-xs font-bold uppercase tracking-wider text-slate-500">Speed</label>
          <span id="speedValue" class="text-xs font-semibold text-slate-600">1.0x</span>
        </div>
        <input type="range" id="speechRate" min="0.5" max="2" step="0.1" value="1.0" class="w-full accent-indigo-600" oninput="document.getElementById('speedValue').textContent = this.value + 'x'">
      </div>
      <!-- Pitch -->
      <div>
        <div class="flex justify-between items-center mb-1">
          <label class="text-xs font-bold uppercase tracking-wider text-slate-500">Voice Pitch</label>
          <span id="pitchValue" class="text-xs font-semibold text-slate-600">1.0</span>
        </div>
        <input type="range" id="speechPitch" min="0.5" max="1.5" step="0.1" value="1.0" class="w-full accent-indigo-600" oninput="document.getElementById('pitchValue').textContent = this.value">
      </div>
      <!-- Continuous TTS Toggle -->
      <div class="pt-4 border-t border-slate-100 flex items-center justify-between">
        <div>
          <span class="block text-sm font-semibold text-slate-800">Auto Speak</span>
          <span class="text-xs text-slate-400">Speak AI responses back automatically</span>
        </div>
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="autoSpeakToggle" class="sr-only peer" checked>
          <div class="w-9 h-5 bg-slate-200 rounded-full peer peer-checked:bg-indigo-600 peer-checked:after:translate-x-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all"></div>
        </label>
      </div>
    </div>
  </div>

  <div class="flex-1 flex flex-col h-screen relative z-10">
    
    <!-- Premium Header -->
    <header class="w-full h-20 flex items-center justify-between px-8 bg-white/70 backdrop-blur-xl border-b border-slate-100/80 sticky top-0 z-30">
      <div class="flex items-center gap-3.5">
        <div class="h-10 w-10 bg-indigo-600 rounded-2xl flex items-center justify-center shadow-lg shadow-indigo-500/20 transition-transform hover:scale-105">
          <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div>
          <h1 class="font-bold text-slate-900 tracking-tight text-base leading-tight">Agent Intelligence</h1>
          <div class="flex items-center gap-1.5 mt-0.5">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
            <span class="text-[11px] font-medium text-slate-400 tracking-wide uppercase">Core System v2.4</span>
          </div>
        </div>
      </div>

      <!-- Center Waveform status -->
      <div class="hidden md:flex items-center gap-3">
        <div id="visWaveform" class="waveform">
          <span class="wave-bar"></span>
          <span class="wave-bar"></span>
          <span class="wave-bar"></span>
          <span class="wave-bar"></span>
          <span class="wave-bar"></span>
          <span class="wave-bar"></span>
          <span class="wave-bar"></span>
        </div>
        <span id="voiceStatus" class="text-xs font-semibold text-indigo-600">Ready</span>
      </div>

      <!-- User controls -->
      <div class="flex items-center gap-3">
        <!-- Settings Trigger -->
        <button onclick="toggleDrawer()" class="p-2.5 bg-white border border-slate-200/50 hover:bg-slate-50 text-slate-600 rounded-xl transition-all shadow-sm">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"/></svg>
        </button>
      </div>
    </header>

    <main id="chat-container" class="flex-1 overflow-y-auto w-full mx-auto max-w-4xl px-8 py-10 space-y-8 pb-48">
      <% if (chatHistory.length===0) { %>
        <!-- Enhanced Empty State Welcome -->
        <div class="flex flex-col items-center justify-center min-h-[50vh] space-y-8 max-w-lg mx-auto text-center mt-6">
          <div class="relative">
            <div class="absolute -inset-1 bg-gradient-to-r from-indigo-500 to-purple-500 rounded-3xl blur-md opacity-25 animate-pulse"></div>
            <div class="relative w-16 h-16 bg-white rounded-2xl border border-slate-100 flex items-center justify-center shadow-xl">
              <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742h.008v.008h-.008v-.008zM12 10.742h.008v.008H12v-.008zm3.308 0h.008v.008h-.008v-.008zM12 21a9.003 9.003 0 008.361-5.653 1.996 1.996 0 00-.573-2.115 10.02 10.02 0 01-2.236-3.21 10.02 10.02 0 01-1.162-4.4 2.25 2.25 0 00-2.25-2.25h-5.04a2.25 2.25 0 00-2.25 2.25 10.02 10.02 0 01-1.162 4.4 10.02 10.02 0 01-2.236 3.21 1.996 1.996 0 00-.573 2.115A9.003 9.003 0 0012 21z"/></svg>
            </div>
          </div>
          <div>
            <h2 class="text-2xl font-bold text-slate-800 tracking-tight">Meet your Voice Companion</h2>
            <p class="text-slate-500 text-sm mt-2 leading-relaxed">
              Click the 🎤 button to speak, or type your message below.
            </p>
          </div>
          <!-- Prompt Starter Cards -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 w-full pt-4">
            <button onclick="usePrompt('How can I optimize my productivity using AI assistants?')" class="p-4 bg-white hover:bg-slate-50 border border-slate-100 rounded-2xl text-left text-xs transition-all hover:scale-[1.01] hover:shadow-md shadow-sm">
              <span class="block font-bold text-slate-700 mb-1">⚡ Increase Productivity</span>
              <span class="text-slate-400">Optimize daily workflow patterns</span>
            </button>
            <button onclick="usePrompt('Give me 3 innovative concepts for a mobile SaaS business.')" class="p-4 bg-white hover:bg-slate-50 border border-slate-100 rounded-2xl text-left text-xs transition-all hover:scale-[1.01] hover:shadow-md shadow-sm">
              <span class="block font-bold text-slate-700 mb-1">💡 SaaS Brainstorming</span>
              <span class="text-slate-400">Fresh creative tech ideas</span>
            </button>
          </div>
        </div>
      <% } else { %>
        <% chatHistory.forEach((msg, index)=> { %>
          <% const messageText=msg.parts[0].text; %>
          <% const isLast = index === chatHistory.length - 1; %>
          <% const isAI = msg.role !== 'user'; %>
          <div class="w-full msg-card">
            <div class="flex gap-5 <%= msg.role === 'user' ? 'flex-row-reverse' : '' %>">
              <!-- Avatar -->
              <div class="shrink-0">
                <div class="w-10 h-10 rounded-2xl flex items-center justify-center text-xs font-bold shadow-sm border select-none
                  <%= msg.role === 'user' ? 
                  'bg-slate-900 border-slate-800 text-white' : 
                  'bg-white border-slate-200 text-indigo-600' %>">
                  <%= msg.role==='user' ? 'ME' : 'AI' %>
                </div>
              </div>
              <!-- Message Body -->
              <div class="flex flex-col max-w-[80%] <%= msg.role === 'user' ? 'items-end' : 'items-start' %>">
                <div class="relative group p-5 rounded-[22px] text-[15px] leading-relaxed shadow-sm transition-all
                  <%= msg.role === 'user' ? 
                  'bg-indigo-600 text-white rounded-tr-none' : 
                  'bg-white border border-slate-100/80 text-slate-700 rounded-tl-none' %>">
                  <% if (messageText && messageText.trim().length > 0) { %>
                    <% if (isAI) { %>
                      <div class="markdown-content ai-message-text <%= (isAI && isLast) ? 'typewriter-target' : '' %>">
                        <%= messageText %>
                      </div>
                    <% } else { %>
                      <div class="whitespace-pre-line ai-message-text <%= (isAI && isLast) ? 'typewriter-target' : '' %>">
                        <%= messageText %>
                      </div>
                    <% } %>
                  <% } %>
                  <!-- Floating Action Controls (only on AI answers) -->
                  <% if (isAI) { %>
                    <div class="absolute -bottom-3.5 right-4 opacity-0 group-hover:opacity-100 focus-within:opacity-100 transition-opacity flex items-center gap-1.5 z-10 bg-white px-2 py-1 rounded-full border border-slate-200 shadow-sm">
                      <button onclick="readAloud(this)" class="p-1 hover:bg-slate-100 rounded text-slate-500 hover:text-slate-800" title="Speak Aloud">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 6v12m0 0l-4-4H6a2 2 0 01-2-2v-4a2 2 0 012-2h2l4-4v12z"/></svg>
                      </button>
                      <button onclick="copyToClipboard(this)" class="p-1 hover:bg-slate-100 rounded text-slate-500 hover:text-slate-800" title="Copy Content">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
                      </button>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } %>
    </main>

    <footer class="fixed bottom-0 left-0 right-0 p-8 z-20">
      <div class="max-w-3xl mx-auto relative">
        <div class="glass-input rounded-[28px] p-2 flex items-center gap-2 transition-all focus-within:ring-4 focus-within:ring-indigo-500/10 focus-within:border-indigo-500/30">
          <!-- Speech Visualizer -->
          <div id="inlineWaveform" class="waveform hidden px-3">
            <span class="wave-bar bg-red-500"></span>
            <span class="wave-bar bg-red-500"></span>
            <span class="wave-bar bg-red-500"></span>
            <span class="wave-bar bg-red-500"></span>
            <span class="wave-bar bg-red-500"></span>
          </div>
          <textarea 
            id="messageTextArea"
            rows="1" 
            placeholder="Type your message..." 
            class="flex-1 bg-transparent border-none outline-none px-4 py-3.5 text-[15px] text-slate-700 resize-none placeholder-slate-400 max-h-36"
            required
          ></textarea>
          <!-- Voice Mic Trigger Button -->
          <button type="button" id="voiceBtn" class="h-11 w-11 rounded-full flex items-center justify-center text-slate-500 hover:bg-slate-100 hover:text-slate-800 transition-all shadow-sm bg-slate-50 border border-slate-100" title="Voice input">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
            </svg>
          </button>
          <!-- Auto send checkbox -->
          <label class="hidden md:flex items-center gap-1.5 text-xs text-slate-400 cursor-pointer bg-slate-50 border border-slate-100 rounded-full px-3 py-2">
            <input type="checkbox" id="autoSubmitVoice" class="w-3.5 h-3.5 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500" checked />
            <span class="font-medium">Auto‑send</span>
          </label>
          <!-- Submit button -->
          <button type="button" id="sendBtn" class="h-11 px-6 bg-slate-900 hover:bg-indigo-600 text-white rounded-[20px] text-sm font-semibold transition-all active:scale-95 flex items-center gap-2 shadow-md">
            <span id="btnText">Send</span>
            <svg id="btnIcon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        </div>
        <!-- Voice engine status texts footer -->
        <div class="text-center text-[11px] text-slate-400 mt-3 tracking-wide font-medium flex items-center justify-center gap-2">
          <span id="footerStatus" class="font-semibold text-indigo-600"></span>
        </div>
      </div>
    </footer>
  </div>

  <script>
    // ---------- DOM Elements ----------
    const container = document.getElementById('chat-container');
    const tx = document.getElementById('messageTextArea');
    const voiceBtn = document.getElementById('voiceBtn');
    const autoSubmitCheck = document.getElementById('autoSubmitVoice');
    const footerStatus = document.getElementById('footerStatus');
    const sendBtn = document.getElementById('sendBtn');
    const btnText = document.getElementById('btnText');
    const btnIcon = document.getElementById('btnIcon');
    const visWaveform = document.getElementById('visWaveform');
    const inlineWaveform = document.getElementById('inlineWaveform');
    const voiceSelect = document.getElementById('voiceSelect');
    const speechRate = document.getElementById('speechRate');
    const speechPitch = document.getElementById('speechPitch');
    const autoSpeakToggle = document.getElementById('autoSpeakToggle');

    let isSubmitting = false;
    let recognitionInstance = null;
    let isListening = false;

    // ---------- Load System Voices ----------
    function loadVoices() {
      if (!('speechSynthesis' in window)) return;
      let voices = window.speechSynthesis.getVoices();
      voiceSelect.innerHTML = '';
      let englishVoices = voices.filter(v => v.lang.startsWith('en'));
      let voicesToUse = englishVoices.length > 0 ? englishVoices : voices;
      voicesToUse.forEach(voice => {
        const option = document.createElement('option');
        option.value = voice.name;
        option.textContent = `${voice.name} (${voice.lang})`;
        voiceSelect.appendChild(option);
      });
    }

    if ('speechSynthesis' in window) {
      window.speechSynthesis.onvoiceschanged = loadVoices;
      loadVoices();
    }

    // ---------- Text-to-Speech ----------
    function speakText(text, callback) {
      if (!('speechSynthesis' in window)) { if (callback) callback(); return; }
      window.speechSynthesis.cancel();
      const utterance = new SpeechSynthesisUtterance(text);
      utterance.rate = parseFloat(speechRate.value);
      utterance.pitch = parseFloat(speechPitch.value);
      const selectedVoiceName = voiceSelect.value;
      if (selectedVoiceName) {
        const selectedVoice = window.speechSynthesis.getVoices().find(v => v.name === selectedVoiceName);
        if (selectedVoice) utterance.voice = selectedVoice;
      }
      utterance.onstart = () => {
        visWaveform.classList.add('active');
        voiceBtn.classList.add('speaking-indicator');
      };
      utterance.onend = () => {
        visWaveform.classList.remove('active');
        voiceBtn.classList.remove('speaking-indicator');
        if (callback) callback();
      };
      utterance.onerror = () => {
        visWaveform.classList.remove('active');
        voiceBtn.classList.remove('speaking-indicator');
        if (callback) callback();
      };
      window.speechSynthesis.speak(utterance);
    }

    // ---------- Helper Functions ----------
    function toggleDrawer() {
      document.getElementById('settingsDrawer').classList.toggle('translate-x-full');
    }

    function usePrompt(promptText) {
      tx.value = promptText;
      tx.focus();
      tx.style.height = 'auto';
      tx.style.height = (tx.scrollHeight) + 'px';
    }

    function copyToClipboard(button) {
      const card = button.closest('.relative');
      const text = card.querySelector('.markdown-content')?.innerText || card.querySelector('.ai-message-text')?.innerText || '';
      const el = document.createElement('textarea');
      el.value = text;
      document.body.appendChild(el);
      el.select();
      document.execCommand('copy');
      document.body.removeChild(el);
      const oldHTML = button.innerHTML;
      button.innerHTML = `<svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>`;
      setTimeout(() => { button.innerHTML = oldHTML; }, 2000);
    }

    function readAloud(button) {
      const textElement = button.closest('.relative').querySelector('.markdown-content') || button.closest('.relative').querySelector('.ai-message-text');
      if (textElement) speakText(textElement.innerText);
    }

    // ---------- Message Rendering with Markdown ----------
    function escapeHtml(str) {
      if (!str) return '';
      return str.replace(/[&<>]/g, m => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;' })[m] || m);
    }

    function renderMarkdown(text) {
      if (typeof marked !== 'undefined' && marked.parse) {
        return marked.parse(text);
      }
      return escapeHtml(text);
    }

    function addUserMessageToUI(text) {
      const div = document.createElement('div');
      div.className = 'w-full msg-card';
      div.innerHTML = `
        <div class="flex gap-5 flex-row-reverse">
          <div class="shrink-0"><div class="w-10 h-10 rounded-2xl flex items-center justify-center text-xs font-bold shadow-sm border bg-slate-900 border-slate-800 text-white select-none">ME</div></div>
          <div class="flex flex-col max-w-[80%] items-end">
            <div class="p-5 rounded-[22px] text-[15px] leading-relaxed shadow-sm bg-indigo-600 text-white rounded-tr-none">
              <div class="whitespace-pre-line">${escapeHtml(text)}</div>
            </div>
          </div>
        </div>
      `;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;
    }

    function addAIMessageToUI(text, speak = true) {
      const div = document.createElement('div');
      div.className = 'w-full msg-card';
      const htmlContent = renderMarkdown(text);
      div.innerHTML = `
        <div class="flex gap-5">
          <div class="shrink-0"><div class="w-10 h-10 rounded-2xl flex items-center justify-center text-xs font-bold shadow-sm border bg-white border-slate-200 text-indigo-600 select-none">AI</div></div>
          <div class="flex flex-col max-w-[80%] items-start">
            <div class="p-5 rounded-[22px] text-[15px] leading-relaxed shadow-sm bg-white border border-slate-100/80 text-slate-700 rounded-tl-none relative group">
              <div class="markdown-content ai-message-text typewriter-target">${htmlContent}</div>
              <div class="absolute -bottom-3.5 right-4 opacity-0 group-hover:opacity-100 focus-within:opacity-100 transition-opacity flex items-center gap-1.5 z-10 bg-white px-2 py-1 rounded-full border border-slate-200 shadow-sm">
                <button onclick="readAloud(this)" class="p-1 hover:bg-slate-100 rounded text-slate-500 hover:text-slate-800" title="Speak Aloud"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.536 8.464a5 5 0 010 7.072M12 6v12m0 0l-4-4H6a2 2 0 01-2-2v-4a2 2 0 012-2h2l4-4v12z"/></svg></button>
                <button onclick="copyToClipboard(this)" class="p-1 hover:bg-slate-100 rounded text-slate-500 hover:text-slate-800" title="Copy Content"><svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg></button>
              </div>
            </div>
          </div>
        </div>
      `;
      container.appendChild(div);
      container.scrollTop = container.scrollHeight;

      // Typewriter effect on the newly added content
      const targetDiv = div.querySelector('.typewriter-target');
      if (targetDiv) {
        const fullText = targetDiv.innerText;
        targetDiv.innerText = '';
        targetDiv.classList.add('typing');
        let i = 0;
        const speed = 10;
        function typeWriter() {
          if (i < fullText.length) {
            targetDiv.innerText += fullText.charAt(i);
            i++;
            container.scrollTop = container.scrollHeight;
            setTimeout(typeWriter, speed);
          } else {
            targetDiv.classList.remove('typing');
            if (autoSpeakToggle.checked && speak) {
              speakText(fullText);
            }
          }
        }
        typeWriter();
      }
    }

    // ---------- Re‑render existing messages on page load ----------
    function reRenderExistingMessages() {
      document.querySelectorAll('.markdown-content').forEach(el => {
        if (!el.dataset.rendered) {
          const raw = el.innerText;
          const rendered = renderMarkdown(raw);
          el.innerHTML = rendered;
          el.dataset.rendered = 'true';
        }
      });
    }

    // ---------- Send Message ----------
    async function sendMessage(message) {
      if (isSubmitting || !message.trim()) return;
      isSubmitting = true;
      sendBtn.disabled = true;
      btnText.innerText = "Thinking...";
      btnIcon.classList.add('animate-spin');
      tx.readOnly = true;
      tx.classList.add('loading-shimmer');
      
      addUserMessageToUI(message);
      tx.value = '';
      tx.style.height = 'auto';
      
      try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), 60000);
        const response = await fetch('/ask?ajax=1', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json' },
          body: new URLSearchParams({ message: message }),
          signal: controller.signal
        });
        clearTimeout(timeoutId);
        let data;
        try { data = await response.json(); } catch(e) { window.location.reload(); return; }
        if (!response.ok || data.error) throw new Error(data.error || `Server error: ${response.status}`);
        if (data.redirectUrl && data.redirectUrl.trim()) {
          window.open(data.redirectUrl, '_blank');
          addAIMessageToUI(`🌐 Redirecting you dynamically to ${data.redirectUrl.replace(/^https?:\/\//, '').split('/')[0]}...`, false);
        } else if (data.response && data.response.trim()) {
          addAIMessageToUI(data.response, true);
        } else {
          addAIMessageToUI("Command execution completed successfully.", true);
        }
      } catch (err) {
        console.error('Send error:', err);
        let errorMsg = err.name === 'AbortError' ? 'Request timed out (60s).' : err.message;
        addAIMessageToUI(`⚠️ System Error: ${errorMsg}. Please try again.`, false);
        footerStatus.innerText = `Error: ${errorMsg}`;
      } finally {
        sendBtn.disabled = false;
        btnText.innerText = "Send";
        btnIcon.classList.remove('animate-spin');
        tx.readOnly = false;
        tx.classList.remove('loading-shimmer');
        isSubmitting = false;
      }
    }

    // ---------- Speech Recognition (Simple Click‑to‑Talk) ----------
    function startListening() {
      if (isListening) return;
      if (recognitionInstance) {
        recognitionInstance.stop();
        recognitionInstance = null;
      }

      const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
      if (!SpeechRecognition) {
        footerStatus.innerText = "Speech API not supported.";
        return;
      }

      recognitionInstance = new SpeechRecognition();
      recognitionInstance.continuous = false;  // stop after one utterance
      recognitionInstance.interimResults = true;
      recognitionInstance.lang = 'en-US';

      recognitionInstance.onstart = () => {
        isListening = true;
        voiceBtn.classList.add('mic-listening');
        visWaveform.classList.add('active');
        inlineWaveform.classList.remove('hidden');
        inlineWaveform.classList.add('active');
        footerStatus.innerText = '🎤 Listening...';
      };

      recognitionInstance.onresult = (event) => {
        let final = '';
        let interim = '';
        for (let i = event.resultIndex; i < event.results.length; i++) {
          const transcript = event.results[i][0].transcript;
          if (event.results[i].isFinal) final += transcript;
          else interim += transcript;
        }
        const text = final || interim;
        if (text.trim()) {
          tx.value = text;
          tx.style.height = 'auto';
          tx.style.height = (tx.scrollHeight) + 'px';
          footerStatus.innerText = `📝 "${text}"`;
        }
        if (final && autoSubmitCheck.checked) {
          // Auto‑send after final result
          stopListening();
          sendMessage(final);
        }
      };

      recognitionInstance.onerror = (event) => {
        console.error("Speech error:", event.error);
        footerStatus.innerText = `❌ ${event.error}`;
        stopListening();
      };

      recognitionInstance.onend = () => {
        stopListening();
      };

      recognitionInstance.start();
    }

    function stopListening() {
      if (recognitionInstance) {
        try { recognitionInstance.stop(); } catch(e) {}
        recognitionInstance = null;
      }
      isListening = false;
      voiceBtn.classList.remove('mic-listening');
      visWaveform.classList.remove('active');
      inlineWaveform.classList.remove('active');
      inlineWaveform.classList.add('hidden');
      if (!footerStatus.innerText.includes('Error')) {
        footerStatus.innerText = '';
      }
    }

    // ---------- Event Listeners ----------
    voiceBtn.addEventListener('click', () => {
      if (isListening) {
        stopListening();
      } else {
        startListening();
      }
    });

    // If the user types and presses Enter or clicks Send, stop listening
    sendBtn.addEventListener('click', () => {
      if (isListening) stopListening();
      const msg = tx.value.trim();
      if (msg) sendMessage(msg);
    });

    tx.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        if (isListening) stopListening();
        const msg = tx.value.trim();
        if (msg) sendMessage(msg);
      }
    });

    tx.addEventListener('input', function() {
      this.style.height = 'auto';
      this.style.height = (this.scrollHeight) + 'px';
    });

    // ---------- Init ----------
    document.addEventListener('DOMContentLoaded', () => {
      reRenderExistingMessages();
      tx.focus();

      // Handle typewriter for initial messages (if any)
      const target = document.querySelector('.typewriter-target');
      if (target) {
        const fullText = target.innerText;
        target.innerText = '';
        target.classList.add('typing');
        let i = 0;
        const speed = 10;
        function typeWriter() {
          if (i < fullText.length) {
            target.innerText += fullText.charAt(i);
            i++;
            container.scrollTop = container.scrollHeight;
            setTimeout(typeWriter, speed);
          } else {
            target.classList.remove('typing');
            if (autoSpeakToggle.checked) speakText(fullText);
          }
        }
        typeWriter();
      }

      // Wake lock to prevent screen dimming
      if ('wakeLock' in navigator) {
        try {
          navigator.wakeLock.request('screen').then(lock => console.log('🔒 Wake lock acquired')).catch(() => {});
        } catch(e) {}
      }
    });

    <% if (redirectUrl) { %>
      console.log("Opening redirect URL: <%= redirectUrl %>");
      window.open("<%= redirectUrl %>", "_blank");
    <% } %>
  </script>
</body>
</html>